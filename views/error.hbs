<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - My Sawit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl p-10 border border-gray-100 text-center">
        <div class="inline-flex items-center justify-center bg-red-100 p-4 rounded-full text-red-600 mb-6">
            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                </path>
            </svg>
        </div>

        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">{{status}}</h1>
        <p class="text-xl font-bold text-gray-700 mb-4">Waduh, ada kendala!</p>
        <p class="text-gray-500 mb-8">{{message}}</p>

        <div class="space-y-3">
            <a href="/"
                class="block w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-green-100 transition-all">
                Kembali ke Dashboard
            </a>
            <button onclick="window.history.back()"
                class="block w-full bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold py-3 rounded-xl transition-all">
                Kembali ke Halaman Sebelumnya
            </button>
        </div>

        <div class="mt-8 text-xs text-gray-400">
            Path: <span class="font-mono">{{path}}</span>
        </div>
    </div>
</body>

</html>