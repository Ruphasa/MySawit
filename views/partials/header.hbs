<header class="bg-white border-b border-slate-200 h-20 flex items-center justify-between px-8 sticky top-0 z-10">
    <div>
        <h1 class="text-xl font-bold text-slate-800">{{title}}</h1>
        <p class="text-xs text-slate-500 font-medium uppercase tracking-widest mt-1">Dashboard{{title}}</p>
    </div>

    <div class="flex items-center gap-4">
        <div class="text-right">
            <p class="text-sm font-bold text-slate-800">{{user.username}}</p>
            <p class="text-[10px] bg-emerald-100 text-emerald-700 font-bold px-2 py-0.5 rounded-full uppercase">Administrator</p>
        </div>
        <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center border-2 border-white shadow-sm overflow-hidden">
            <img src="https://ui-avatars.com/api/?name={{user.username}}&background=059669&color=fff" alt="Avatar">
        </div>
    </div>
</header>