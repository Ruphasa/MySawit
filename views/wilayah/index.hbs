{{#> layout}}
    <div class="mb-8 flex justify-between items-end">
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-gray-900">Data Wilayah</h1>
            <p class="text-gray-500 mt-1">Manajemen blok dan area perkebunan sawit.</p>
        </div>
        <a href="/wilayah/create" class="inline-flex items-center px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-xl transition-all shadow-md shadow-green-100 gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
            Tambah Wilayah
        </a>
    </div>

    <!-- Search Section -->
    <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm mb-6">
        <form action="/wilayah" method="GET" class="flex gap-4">
            <div class="relative flex-1">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" name="search" value="{{search}}" 
                    class="block w-full pl-10 pr-3 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-green-100 focus:border-green-500 outline-none transition-all sm:text-sm" 
                    placeholder="Cari berdasarkan nama wilayah atau lokasi...">
            </div>
            <button type="submit" class="px-6 py-2.5 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-xl transition-colors">
                Search
            </button>
            {{#if search}}
            <a href="/wilayah" class="px-4 py-2.5 text-gray-500 hover:text-gray-700 font-medium flex items-center">Reset</a>
            {{/if}}
        </form>
    </div>

    <!-- Table Section -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <table class="w-full text-left">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">ID</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Nama Wilayah</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Luas (Ha)</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Lokasi</th>
                    <th class="px-6 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-widest">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {{#each wilayah}}
                <tr class="hover:bg-gray-50 transition-colors group">
                    <td class="px-6 py-4 text-sm text-gray-400">{{this.id}}</td>
                    <td class="px-6 py-4 font-semibold text-gray-900">{{this.nama_wilayah}}</td>
                    <td class="px-6 py-4 text-sm text-gray-600">{{this.luas_hektar}}</td>
                    <td class="px-6 py-4 text-sm text-gray-500">{{this.lokasi}}</td>
                    <td class="px-6 py-4 text-right space-x-2">
                        <a href="/wilayah/{{this.id}}" class="inline-flex items-center px-3 py-1.5 bg-gray-100 text-gray-700 text-xs font-bold rounded-lg hover:bg-gray-200 transition-all uppercase">Detail</a>
                        <a href="/wilayah/{{this.id}}/edit" class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 text-xs font-bold rounded-lg hover:bg-blue-100 transition-all uppercase">Edit</a>
                        <form action="/wilayah/{{this.id}}/delete" method="POST" class="inline">
                            <button type="submit" onclick="return confirm('Apakah Anda yakin ingin menghapus data ini?')" 
                                class="inline-flex items-center px-3 py-1.5 bg-red-50 text-red-600 text-xs font-bold rounded-lg hover:bg-red-100 transition-all uppercase">Hapus</button>
                        </form>
                    </td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center">
                        <div class="text-gray-400">
                            <svg class="w-12 h-12 mx-auto mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                            <p class="text-lg font-medium">Data tidak ditemukan</p>
                            <p class="text-sm">Silakan buat data wilayah baru.</p>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
{{/layout}}
