{{#> layout}}
    <div class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a href="/wilayah" class="p-2 hover:bg-gray-100 rounded-full transition-colors text-gray-500">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            </a>
            <div>
                <h1 class="text-3xl font-bold tracking-tight text-gray-900">{{item.nama_wilayah}}</h1>
                <p class="text-gray-500 mt-1">Informasi lengkap dan histori panen.</p>
            </div>
        </div>
        <div class="flex gap-2">
            <a href="/wilayah/{{item.id}}/edit" class="px-5 py-2.5 bg-gray-900 text-white text-sm font-bold rounded-xl hover:bg-gray-800 transition-all">Edit Data</a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Luas Wilayah</p>
            <p class="text-2xl font-extrabold text-gray-900">{{item.luas_hektar}} <span class="text-sm font-normal text-gray-500">Ha</span></p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Lokasi</p>
            <p class="text-sm font-semibold text-gray-700">{{item.lokasi}}</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Total Panen</p>
            <p class="text-2xl font-extrabold text-green-600">-- <span class="text-sm font-normal text-gray-500">Ton</span></p>
        </div>
    </div>

    <!-- Harvest History -->
    <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4">Histori Panen Harian</h2>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden text-sm">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 font-bold text-gray-500 uppercase tracking-widest">Tanggal</th>
                        <th class="px-6 py-4 font-bold text-gray-500 uppercase tracking-widest">Hasil (Ton)</th>
                        <th class="px-6 py-4 font-bold text-gray-500 uppercase tracking-widest">Catatan</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    {{#each item.laporan_harian}}
                    <tr>
                        <td class="px-6 py-4 font-semibold">{{this.tanggal}}</td>
                        <td class="px-6 py-4 text-green-700 font-bold">{{this.jumlah_panen_ton}} Ton</td>
                        <td class="px-6 py-4 text-gray-500 italic">{{this.catatan}}</td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-gray-400">Belum ada laporan panen untuk wilayah ini.</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
{{/layout}}
