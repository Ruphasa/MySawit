{{#> layout}}
    <div class="mb-8 flex items-center gap-4">
        <a href="/laporan" class="p-2 hover:bg-gray-100 rounded-full transition-colors text-gray-500">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        </a>
        <div>
            <h1 class="text-3xl font-bold tracking-tight text-gray-900">Detail Laporan Panen</h1>
            <p class="text-gray-500 mt-1">Informasi lengkap aktivitas panen wilayah.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Info -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 mb-2">
                            {{item.wilayah.nama_wilayah}}
                        </span>
                        <h2 class="text-2xl font-bold text-gray-900">{{item.tanggal}}</h2>
                    </div>
                    <div class="text-right">
                        <p class="text-sm text-gray-500 uppercase tracking-widest font-bold">Hasil Panen</p>
                        <p class="text-3xl font-black text-green-600">{{item.jumlah_panen_ton}} <span class="text-lg font-normal">Ton</span></p>
                    </div>
                </div>

                <div class="border-t border-gray-50 pt-8">
                    <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">Catatan Tambahan</h3>
                    <div class="bg-gray-50 rounded-xl p-6 text-gray-700 italic border-l-4 border-green-200">
                        {{#if item.catatan}}
                            "{{item.catatan}}"
                        {{else}}
                            Tidak ada catatan untuk laporan ini.
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div class="space-y-6">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Aksi Laporan</h3>
                <div class="space-y-3">
                    <a href="/laporan/{{item.id}}/edit" 
                        class="flex items-center justify-center gap-2 w-full py-3 bg-blue-50 text-blue-600 font-bold rounded-xl hover:bg-blue-100 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        Edit Laporan
                    </a>
                    <form action="/laporan/{{item.id}}/delete" method="POST">
                        <button type="submit" onclick="return confirm('Hapus laporan ini secara permanen?')"
                            class="flex items-center justify-center gap-2 w-full py-3 bg-red-50 text-red-600 font-bold rounded-xl hover:bg-red-100 transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            Hapus Laporan
                        </button>
                    </form>
                </div>
            </div>

            <div class="bg-green-600 rounded-2xl p-6 text-white shadow-lg shadow-green-100">
                <h3 class="font-bold mb-2">Info Wilayah</h3>
                <p class="text-green-100 text-sm mb-4">Laporan ini tercatat untuk wilayah {{item.wilayah.nama_wilayah}}.</p>
                <a href="/wilayah/{{item.wilayah_id}}" class="text-white font-bold underline text-sm hover:text-green-200 transition-colors">
                    Lihat Detail Wilayah &rarr;
                </a>
            </div>
        </div>
    </div>
{{/layout}}
